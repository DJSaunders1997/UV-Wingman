{
	"name": "uv-wingman",
	"displayName": "UV Wingman",
	"description": "Help users manage and interact with the python UV package manager.",
	"version": "2.0.0",
	"publisher": "DJSaunders1997",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other",
		"Snippets",
		"Data Science",
		"Machine Learning"
	],
	"icon": "images/Logo-512x512.png",
	"galleryBanner": {
		"color": "#8A2BE2",
		"theme": "dark"
	},
	"keywords": [
		"Python",
		"Environment",
		"Environments",
		"UV",
		"Dependencies",
		"pyproject.toml"
	],
	"preview": false,
	"activationEvents": [
		"workspaceContains:pyproject.toml"
	],
	"main": "./src/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "uv-wingman.refreshDependencies",
				"title": "UV Wingman: Refresh Dependencies"
			},
			{
				"command": "uv-wingman.initProject",
				"title": "UV Wingman: Initialize UV Project"
			},
			{
				"command": "uv-wingman.createEnvironment",
				"title": "UV Wingman: Create Environment from pyproject.toml"
			},
			{
				"command": "uv-wingman.syncDependencies",
				"title": "UV Wingman: Sync Dependencies with pyproject.toml"
			},
			{
				"command": "uv-wingman.deleteEnvironment",
				"title": "UV Wingman: Delete Environment"
			},
			{
				"command": "uv-wingman.activateEnvironment",
				"title": "UV Wingman: Activate UV Environment"
			},
			{
				"command": "uv-wingman.addPackage",
				"title": "UV Wingman: Add Package"
			},
			{
				"command": "uv-wingman.removePackage",
				"title": "UV Wingman: Remove Package"
			},
			{
				"command": "uv-wingman.runScript",
				"title": "UV Wingman: Run Script"
			},
			{
				"command": "uv-wingman.lock",
				"title": "UV Wingman: Lock Dependencies"
			}
		],
		"menus": {
			"view/item/context": [
				{
					"command": "uv-wingman.removePackage",
					"when": "viewItem == dependencyItem",
					"group": "inline"
				}
			]
		},
		"configuration": {
			"title": "UV Wingman",
			"properties": {
				"uvWingman.envName": {
					"type": "string",
					"default": ".venv",
					"description": "Name of the virtual environment directory (e.g., .venv, venv, env)"
				},
				"uvWingman.showStatusBarItems": {
					"type": "boolean",
					"default": true,
					"description": "Show UV Wingman status bar items"
				},
				"uvWingman.autoSetInterpreter": {
					"type": "boolean",
					"default": true,
					"description": "Automatically set the VS Code Python interpreter when an environment is created or activated"
				}
			}
		},
		"views": {
			"explorer": [
				{
					"id": "uvWingman.dependencies",
					"name": "UV Dependencies"
				}
			]
		}
	},
	"scripts": {
		"lint": "eslint .",
		"pretest": "npm run lint",
		"test": "node ./test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.10.1",
		"@types/vscode": "^1.95.0",
		"@vscode/test-electron": "^2.3.8",
		"eslint": "^8.35.0",
		"glob": "^11.0.0",
		"mocha": "^10.8.2",
		"sinon": "^19.0.2",
		"typescript": "^4.9.5"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/DJSaunders1997/uv-Wingman.git"
	},
	"homepage": "https://github.com/DJSaunders1997/uv-Wingman#readme",
	"dependencies": {
	}
}
